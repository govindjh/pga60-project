{
    "name": "PizzaDashboardTheme",
    "dataColors": ["#006491", "#E31837", "#00A8E8", "#F3722C", "#F94144"],
    "background": "#F3F2F1",
    "foreground": "#252423",
    "tableAccent": "#006491",
    "visualStyles": {
        "*": {
            "*": {
                "background": [{ "show": true, "transparency": 0 }],
                "border": [{ "show": true, "color": { "solid": { "color": "#CCCCCC" } } }],
                "title": [{ "show": true, "fontColor": { "solid": { "color": "#006491" } } }]
            }
        }
    }
}