{
  "name": "PizzaDashboardTheme",
  "dataColors": ["#006491", "#E31837", "#00A8E8", "#F3722C", "#F94144"],
  "background": "#F3F2F1",
  "foreground": "#252423",
  "tableAccent": "#006491",
  "visualStyles": {
    "*": {
      "*": {
        "outspace": [{ "background": { "solid": { "color": "#FFFFFF" } } }],
        "border": [{ "show": true, "color": { "solid": { "color": "#CCCCCC" } }, "radius": 10 }],
        "title": [{ "show": true, "fontColor": { "solid": { "color": "#006491" } }, "fontSize": 14 }]
      }
    }
  }
}